# Application Config
APP_NAME=fastapi-mvc-app
APP_ENV=local
DEBUG=true
PORT=8000
API_V1_STR=/api/v1

# PostgreSQL Database Config
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=chatbot_db

# Security & JWT Config
JWT_SECRET_KEY=secret-super-key-change-in-production-1234567
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Embedding Config
EMBEDDING_PROVIDER=gemini
EMBEDDING_DIMENSION=768
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
HF_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Vector Database Config
VECTOR_DB_PROVIDER=chroma
CHROMA_PERSIST_DIRECTORY=./chroma_db

# Redis Config (Caching & Rate Limiting)
REDIS_URL=redis://localhost:6379/0

# Celery Config (Background Workers)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Rate Limiting
RATE_LIMIT_CHAT=20/minute

# Sentry Error Tracking (optional - leave empty to disable)
SENTRY_DSN=
